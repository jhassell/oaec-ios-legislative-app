                                <animations/>
                                <color key="backgroundColor" white="0.0" alpha="0.0" colorSpace="calibratedWhite"/>
                                <string key="text">The Oklahoma Association of Electric Cooperatives (OAEC) is a statewide association voluntarily supported by local electric distribution and generation/transmission cooperatives. OAEC is comprised of 30 member systems, 28 in Oklahoma and two Arkansas systems with a substantial portion of their membership residing in Oklahoma.</string>
                                <color key="textColor" white="1" alpha="1" colorSpace="calibratedWhite"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="14"/>
                                <textInputTraits key="textInputTraits" autocapitalizationType="sentences"/>
