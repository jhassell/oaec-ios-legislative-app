                                <animations/>
                                <color key="backgroundColor" white="0.0" alpha="0.0" colorSpace="calibratedWhite"/>
                                <string key="text">The purpose of the OAEC Legislative and Regulatory Affairs Department is to represent the member cooperatives in the most professional fashion at both our state and federal capitols.</string>
