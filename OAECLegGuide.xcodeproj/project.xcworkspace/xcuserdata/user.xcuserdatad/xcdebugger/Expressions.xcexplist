            <PersistentString
               value = "chv.roomLabel.text">
            </PersistentString>
            <PersistentString
               value = "self.committee.time">
            </PersistentString>
         </PersistentStrings>
      </ContextState>
      <ContextState
         contextName = "-[PeopleListDelegate yeaButtonTapped:]:PeopleListDelegate.m">
      </ContextState>
      <ContextState
         contextName = "+[DataLoader loadCSVFile:]:DataLoader.m">
      </ContextState>
      <ContextState
         contextName = "-[PeopleListDelegate yeaCheckButtonTapped:row:]:PeopleListDelegate.m">
      </ContextState>
      <ContextState
         contextName = "-[VotingListViewController viewWillAppear:]:VotingListViewController.m">
      </ContextState>
      <ContextState
         contextName = "main:main.m">
      </ContextState>
      <ContextState
         contextName = "-[PeopleListDelegate tableView:numberOfRowsInSection:]:PeopleListDelegate.m">
         <PersistentStrings>
            <PersistentString
               value = "self.parent.tallies[0].votes[rowCount - 1].status">
            </PersistentString>
            <PersistentString
               value = "self.parent.tallies[0].votes[0].status">
            </PersistentString>
         </PersistentStrings>
      </ContextState>
      <ContextState
         contextName = "-[PersonViewController tableView:heightForRowAtIndexPath:]:PersonViewController.m">
         <PersistentStrings>
            <PersistentString
               value = "self.indexPath.row">
            </PersistentString>
            <PersistentString
               value = "self.sections">
            </PersistentString>
         </PersistentStrings>
      </ContextState>
      <ContextState
         contextName = "-[PeopleListDelegate yeaCheckButtonTapped:]:PeopleListDelegate.m">
      </ContextState>
   </ContextStates>
</VariablesViewState>
